# Copy to .env.local (gitignored) and fill in for `scripts/serve-local.sh`.
# Local GitHub OAuth App — Authorization callback URL must be
# http://localhost:7880/api/auth/github/callback
BLOGFORGE_GITHUB_CLIENT_ID=your-local-oauth-app-client-id
BLOGFORGE_GITHUB_CLIENT_SECRET=your-local-oauth-app-client-secret
BLOGFORGE_GITHUB_ALLOWLIST=dbbaskette
BLOGFORGE_GITHUB_ADMIN_LOGIN=dbbaskette
BLOGFORGE_PUBLIC_URL=http://localhost:7880
BLOGFORGE_SESSION_SECRET=change-me-to-a-stable-random-string
